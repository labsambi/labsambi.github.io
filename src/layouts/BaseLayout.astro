---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={Astro.props.description || Astro.props.title} />
    <title>{Astro.props.title} | 我的博客</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-logo">
          <span class="logo-icon">☕</span>
          <span class="logo-text">我的博客</span>
        </a>
        <nav class="site-nav">
          <a href="/">首页</a>
          <a href="/tags">标签</a>
          <a href="/categories">分类</a>
          <a href="/about">关于</a>
        </nav>
      </div>
    </header>

    <main class="site-main container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} 我的博客 · Powered by <a href="https://astro.build" target="_blank">Astro</a></p>
        <p class="footer-sub">用文字记录生活，用代码改变世界</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: rgba(254, 250, 246, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.8rem 0;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.4rem;
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
  }

  .site-nav a {
    color: var(--color-text-light);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .site-nav a:hover {
    color: var(--color-accent);
  }

  .site-main {
    min-height: calc(100vh - 180px);
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    text-align: center;
  }

  .site-footer p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 0.3rem;
  }

  .footer-sub {
    font-size: 0.82rem !important;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .site-nav {
      gap: 1rem;
    }
    .site-nav a {
      font-size: 0.88rem;
    }
    .site-logo {
      font-size: 1.05rem;
    }
  }
</style>

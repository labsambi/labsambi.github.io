---
import { getAllPosts, formatDate } from '../utils/posts';

const posts = await getAllPosts();
const postsData = posts.map((post) => {
  const slug = post.id.replace(/\.mdx?$/, '');
  return {
    title: post.data.title,
    description: post.data.description,
    category: post.data.category,
    tags: post.data.tags,
    date: post.data.date.toISOString(),
    slug,
  };
});
---

<div id="search-container" class="search-box">
  <div class="search-input-wrap">
    <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="text"
      id="search-input"
      class="search-input"
      placeholder="搜索文章..."
      autocomplete="off"
    />
    <button id="search-clear" class="search-clear" type="button" aria-label="清除">×</button>
  </div>
  <div id="search-results" class="search-results hidden"></div>
</div>

<script define:vars={{ postsData }}>
  const posts = postsData as Array<{
    title: string;
    description: string;
    category: string;
    tags: string[];
    date: string;
    slug: string;
  }>;

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLDivElement;
  const searchClear = document.getElementById('search-clear') as HTMLButtonElement;

  function formatDateStr(dateStr: string): string {
    const d = new Date(dateStr);
    return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function search(query: string) {
    if (!query.trim()) {
      searchResults.classList.add('hidden');
      searchClear.classList.remove('visible');
      return;
    }

    searchClear.classList.add('visible');
    const q = query.toLowerCase();
    const results = posts.filter((p) =>
      p.title.toLowerCase().includes(q) ||
      p.description.toLowerCase().includes(q) ||
      p.tags.some((t) => t.toLowerCase().includes(q)) ||
      p.category.toLowerCase().includes(q)
    );

    if (results.length === 0) {
      searchResults.innerHTML = '<p class="no-results">未找到相关文章 🍃</p>';
    } else {
      searchResults.innerHTML = results.map((p) => `
        <a href="/posts/${p.slug}" class="search-result-item">
          <div class="sr-top">
            <span class="sr-category">${p.category}</span>
            <span class="sr-date">${formatDateStr(p.date)}</span>
          </div>
          <h3 class="sr-title">${p.title}</h3>
          <p class="sr-desc">${p.description}</p>
        </a>
      `).join('');
    }
    searchResults.classList.remove('hidden');
  }

  searchInput.addEventListener('input', () => search(searchInput.value));
  searchClear.addEventListener('click', () => {
    searchInput.value = '';
    search('');
    searchInput.focus();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchInput.value = '';
      search('');
      searchInput.blur();
    }
  });
</script>

<style>
  .search-box {
    margin-bottom: 2rem;
    position: relative;
  }

  .search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    color: var(--color-text-light);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.85rem 2.8rem 0.85rem 3rem;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(196, 149, 106, 0.15);
  }

  .search-input::placeholder {
    color: var(--color-text-light);
    opacity: 0.6;
  }

  .search-clear {
    position: absolute;
    right: 0.8rem;
    background: none;
    border: none;
    font-size: 1.3rem;
    color: var(--color-text-light);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    line-height: 1;
  }

  .search-clear.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    max-height: 400px;
    overflow-y: auto;
    z-index: 50;
  }

  .search-results.hidden {
    display: none;
  }

  .search-result-item {
    display: block;
    padding: 1rem 1.2rem;
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s ease;
  }

  .search-result-item:last-child {
    border-bottom: none;
  }

  .search-result-item:hover {
    background: var(--color-bg-alt);
  }

  .sr-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.3rem;
  }

  .sr-category {
    background: var(--color-accent);
    color: #fff;
    padding: 0.05em 0.5em;
    border-radius: 20px;
    font-size: 0.72rem;
  }

  .sr-date {
    font-size: 0.78rem;
    color: var(--color-text-light);
  }

  .sr-title {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .sr-desc {
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  .no-results {
    padding: 2rem;
    text-align: center;
    color: var(--color-text-light);
  }
</style>

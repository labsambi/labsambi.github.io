---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/posts';

export interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, date, tags, category } = post.data;
---

<article class="post-card">
  <div class="card-meta">
    {category && <a href={`/categories/${category}`} class="card-category">{category}</a>}
    <time datetime={date.toISOString()}>{formatDate(date)}</time>
  </div>
  <h2 class="card-title">
    <a href={`/posts/${post.id.replace(/\.mdx?$/, '')}`}>{title}</a>
  </h2>
  <p class="card-desc">{description}</p>
  <div class="card-footer">
    <div class="card-tags">
      {tags.slice(0, 3).map((tag) => (
        <a href={`/tags/${tag}`} class="card-tag">{tag}</a>
      ))}
    </div>
    <a href={`/posts/${post.id.replace(/\.mdx?$/, '')}`} class="card-readmore">
      阅读 →
    </a>
  </div>
</article>

<style>
  .post-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.2rem;
    transition: all 0.25s ease;
    box-shadow: var(--shadow);
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    border-color: var(--color-accent);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.6rem;
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .card-category {
    background: var(--color-accent);
    color: #fff !important;
    padding: 0.1em 0.6em;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 500;
  }

  .card-title {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
  }

  .card-title a {
    color: var(--color-text);
  }

  .card-title a:hover {
    color: var(--color-accent);
  }

  .card-desc {
    color: var(--color-text-light);
    font-size: 0.92rem;
    margin-bottom: 0.8rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-tag {
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 0.1em 0.5em;
    border-radius: 20px;
    font-size: 0.78rem;
    transition: all 0.2s ease;
  }

  .card-tag:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .card-readmore {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .card-readmore:hover {
    color: var(--color-accent-hover);
  }
</style>
